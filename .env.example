# ─── AI（必选其一）───────────────────────────────────────────
DEEPSEEK_API_KEY=          # 推荐：便宜，评分/改写都够用
OPENAI_API_KEY=
DASHSCOPE_API_KEY=         # 阿里通义
# 自定义 API base（如 zjz-ai.webtrn.cn）
OPENAI_API_BASE=

# 默认使用的模型（litellm 格式）
NEWSFLOW_MODEL=deepseek/deepseek-chat
# 评分用模型（便宜）
NEWSFLOW_SCORE_MODEL=deepseek/deepseek-chat
# 生成用模型（质量高）
NEWSFLOW_GENERATE_MODEL=deepseek/deepseek-chat

# ─── 采集源（按需配置）──────────────────────────────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=NewsFlow/0.1
APIFY_TOKEN=               # Twitter 采集（可选）
NEWSNOW_BASE_URL=https://newsnow.busiyi.world  # 中文热榜 API

# ─── 推送（按需配置）────────────────────────────────────────
FEISHU_WEBHOOK_URL=
DINGTALK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── 发布（按需配置）────────────────────────────────────────
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# ─── 存储 ────────────────────────────────────────────────────
DATA_DIR=./data
